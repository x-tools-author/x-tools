    "cmake.buildDirectory": "${workspaceFolder}/build/${buildKit}/${buildType}",
    "[typescript]": {
        "editor.formatOnSave": false
    },
    "qt-ui.customWidgetsDesignerExePath": "${workspaceFolder}/tools/Qt5.6.3/5.6.3/mingw49_32/bin/designer.exe"
