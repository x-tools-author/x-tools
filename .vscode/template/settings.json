        "-DCMAKE_PREFIX_PATH:PATH=${workspaceFolder}/tools/Qt5.6.3/5.6.3/mingw49_32",
        "-DX_USING_VS_CODE:BOOL=ON",
        "-DX_ENABLE_LOG:BOOL=OFF",
        "-DX_ENABLE_X_OPCUA:OFF=OFF",
        "-DX_ENABLE_X_BLE:BOOL=OFF",
        "-DX_ENABLE_X_HTTP:BOOL=OFF",
        "-DX_ENABLE_X_COAP:BOOL=ON",
        "-DX_SETUP_BUILDING_FOR_WIN_XP_ENV:BOOL=ON",
        "-DCMAKE_GENERATOR:STRING=MinGW Makefiles"
